<navigation-bar title="我的yu生" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<view class="container">
  <view class="life-table">
    <view class="table-header">
      <text class="hcell h-label">项目</text>
      <text class="hcell h-value">数值</text>
    </view>
    <view class="table-row">
      <text class="cell label-cell">出生</text>
      <view class="cell value-cell birth-value {{isDefaultBirth ? 'default-birth' : ''}}">
        <text>{{birthDate}}</text>
        <text class="link birth-link" bindtap="goToSettings">修改</text>
      </view>
    </view>
    <view class="table-row" wx:for="{{items}}" wx:key="label" wx:if="{{item.label !== '出生'}}">
      <text class="cell label-cell">{{item.label}}</text>
      <text class="cell value-cell {{item.highlight ? 'highlight' : ''}}">{{item.value}}</text>
    </view>
    <view class="table-row">
      <text class="cell label-cell">比例</text>
      <view class="value-cell">
        <view class="progress-track {{exceeded ? 'exceeded' : ''}}">
          <view class="progress-fill" style="width: {{ratioPercent}}%"></view>
          <text class="progress-text">{{ratioText}}</text>
        </view>
      </view>
    </view>
  </view>
  <view class="footer-text">
    <text wx:if="{{!wish}}" class="link" bindtap="onEditWish">剩下的时间还想干点什么？</text>
    <block wx:else>
      <text class="heart">5 年♥愿</text>
      <text class="wish-text">自 {{wishDate}} 起：{{wish}}</text>
      <text class="link" bindtap="onEditWish">（修改）</text>
    </block>
  </view>
  <view class="author-text"><text class="heart"></text> Made by twinsant</view>
  <button class="share-btn" bindtap="onShareImage">保存图片分享</button>
  <canvas type="2d" id="shareCanvas" class="share-canvas" style="width:750rpx;height:1200rpx"></canvas>
</view>
